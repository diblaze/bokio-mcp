# Copy to .env (gitignored) or export in your shell / MCP client config.

# Required at call time. Bokio -> Installningar -> API Tokens (private integration).
BOKIO_TOKEN=your_private_bearer_token

# Default company (single-AB). Find it in the Bokio browser URL.
BOKIO_COMPANY_ID=your_company_id

# Safety gate. Writes (create/update/delete/publish/record/reverse/upload) are
# BLOCKED unless this is 1/true/yes/on. Leave empty for read-only.
BOKIO_ALLOW_WRITES=

# Optional API base override.
BOKIO_BASE_URL=https://api.bokio.se/v1
