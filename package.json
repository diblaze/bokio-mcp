{
  "name": "bokio-mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server for the Bokio accounting API (private Bearer-token auth, single-company)",
  "type": "module",
  "bin": {
    "bokio-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "smoke": "node scripts/smoke.mjs",
    "prepublishOnly": "npm run build",
    "lint": "biome check",
    "format": "biome check --write",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "license": "MIT",
  "keywords": [
    "mcp",
    "bokio",
    "accounting",
    "bokforing",
    "sie"
  ],
  "packageManager": "pnpm@11.9.0"
}
